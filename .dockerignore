# Root .dockerignore — applies when build context is the repo root (Node services)

# Git
.git/
.gitignore

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment files (never in image layers)
.env
.env.*
.env.local
.env.*.local

# Node build artifacts – recursive (covers packages/*/node_modules etc.)
**/node_modules/
**/.turbo/
**/.next/
**/.next-dev/

# Python artifacts – recursive
**/__pycache__/
**/*.pyc
**/*.pyo
**/.venv/
**/.pytest_cache/

# Next.js build output (rebuilt inside Docker) – explicit path
packages/*/.next/
packages/*/.next-dev/

# Test output
coverage/
htmlcov/

# Kiro / spec files (not needed in images)
.kiro/
.specify/
.augment/
.agent/

# Docker files themselves
docker-compose*.yml
*.dockerfile

# Docs
README*.md
LICENSE