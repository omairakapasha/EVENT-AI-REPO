# ============================================
# Event-AI Backend — Environment Configuration
# ============================================
# Copy this file to .env and fill in the values.
# Variables marked [REQUIRED] must be set before the server will start.
# Variables marked [OPTIONAL] have defaults and can be omitted.

# ─── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development                    # [OPTIONAL] development | production | test
PORT=5000                               # [OPTIONAL] default: 5000
API_VERSION=v1                          # [OPTIONAL] default: v1

# ─── Database (Supabase / PostgreSQL) ─────────────────────────────────────────
# Get from: https://supabase.com/dashboard/project/_/settings/database
# Use "Transaction pooler" URL for runtime, "Direct connection" URL for migrations.
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres

# ─── Redis (Optional) ─────────────────────────────────────────────────────────
# Use Upstash Redis (https://upstash.com) or a local Redis instance.
# [OPTIONAL] — rate limiting and caching degrade gracefully if Redis is unavailable.
REDIS_URL=redis://localhost:6379

# ─── JWT ───────────────────────────────────────────────────────────────────────
# [REQUIRED] — Use 256-bit random secrets (min 32 chars). Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_ALGORITHM=HS256                  # [OPTIONAL] default: HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15      # [OPTIONAL] default: 15
REFRESH_TOKEN_EXPIRE_DAYS=7         # [OPTIONAL] default: 7

# ─── Email / SMTP ──────────────────────────────────────────────────────────────
# [OPTIONAL] — If not set, emails are logged to console only (safe for dev).
# For production, use SendGrid, Resend, Mailgun, or any SMTP provider.
#
# Example — Gmail (App Password):
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_SECURE=false
#   SMTP_USER=you@gmail.com
#   SMTP_PASSWORD=your-app-password
#
# Example — SendGrid:
#   SMTP_HOST=smtp.sendgrid.net
#   SMTP_PORT=587
#   SMTP_SECURE=false
#   SMTP_USER=apikey
#   SMTP_PASSWORD=your-sendgrid-api-key
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@eventai.pk

# ─── Frontend URL (for email links & post-OAuth redirects) ────────────────────
# [OPTIONAL] — Used in email verification, password reset links, and Google OAuth redirects.
FRONTEND_URL=http://localhost:3003

# ─── Google OAuth 2.0 ─────────────────────────────────────────────────────────
# [OPTIONAL] — Required only if Google Sign-In is enabled.
# Setup: https://console.cloud.google.com/apis/credentials
#   1. Create an OAuth 2.0 Client ID (Web application)
#   2. Add Authorized Redirect URI: http://localhost:5000/api/v1/auth/google/callback
#   3. Copy the Client ID and Client Secret below
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must exactly match the URI registered in Google Cloud Console
GOOGLE_REDIRECT_URI=http://localhost:5000/api/v1/auth/google/callback

# ─── CORS ──────────────────────────────────────────────────────────────────────
# [OPTIONAL] — Comma-separated list of allowed origins.
CORS_ORIGINS=http://localhost:3002,http://localhost:3003,http://localhost:3004

# ─── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000             # [OPTIONAL] 15 minutes
RATE_LIMIT_MAX_REQUESTS=100            # [OPTIONAL] requests per window

# ─── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info                          # [OPTIONAL] error | warn | info | debug

# ─── Supabase (if using Supabase Auth/Storage) ────────────────────────────────
# [OPTIONAL] — Only needed if using Supabase-specific features.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── CDN / Object Storage (S3-compatible, e.g., Cloudflare R2 or AWS S3) ───────
# [REQUIRED] for portfolio image uploads.
CDN_PROVIDER=r2                               # 'r2' or 's3'
S3_ENDPOINT=                                  # e.g., https://<account_id>.r2.cloudflarestorage.com or s3.amazonaws.com
S3_ACCESS_KEY=                                # Access key ID
S3_SECRET_KEY=                                # Secret access key
S3_BUCKET=                                    # Bucket name
S3_REGION=auto                                # For R2 use 'auto', for AWS use region like 'us-east-1'
S3_USE_SSL=true                               # true/false
