# EventAI Agent Service — Environment Variables
# ================================================
# Copy to .env and fill in real values before deploying.
# NEVER commit .env to git. Ensure .env is in .gitignore.

# ── API Authentication ─────────────────────────────────────────────────────
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# Store in secrets manager (AWS Secrets Manager / HashiCorp Vault) in prod.
# Rotate every 90 days.
AI_SERVICE_API_KEY=REPLACE_WITH_STRONG_RANDOM_KEY

# ── Gemini / Google AI ────────────────────────────────────────────────────
# Restrict API key to only Generative Language API in GCP Console.
GEMINI_API_KEY=REPLACE_WITH_GEMINI_KEY

# Enable Gemini-based output safety classifier (LLM > regex)
SHIELDGEMMA_ENABLED=false

# ── Service-to-Service Auth (FIX #4) ──────────────────────────────────────
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
# Set the SAME value as AGENT_SERVICE_SECRET in packages/backend/.env
SERVICE_SECRET=REPLACE_WITH_STRONG_RANDOM_HEX

# ── Backend API ───────────────────────────────────────────────────────────
BACKEND_API_URL=http://localhost:5000/api/v1

# ── CORS ──────────────────────────────────────────────────────────────────
# Production: list only your actual domain. NEVER use "*".
CORS_ORIGINS=http://localhost:3000,http://localhost:3002

# ── Audit Logging (FIX #12) ──────────────────────────────────────────────
# Rotating file log (10 MB / file, 5 backups). Use a persistent path in prod.
AUDIT_LOG_PATH=/var/log/eventai/audit.log

# ── Production Pre-launch Checklist ──────────────────────────────────────
# [ ] .env is NOT committed (run: git ls-files .env — should return nothing)
# [ ] AI_SERVICE_API_KEY is 32+ byte random token
# [ ] SERVICE_SECRET is identical in backend/.env
# [ ] GEMINI_API_KEY restricted to Generative Language API in GCP Console
# [ ] nginx.conf TLS configured with Let's Encrypt certificates
# [ ] AUDIT_LOG_PATH points to a persistent, monitored log volume
# [ ] CORS_ORIGINS lists only your production domain
# [ ] SHIELDGEMMA_ENABLED=true in production
