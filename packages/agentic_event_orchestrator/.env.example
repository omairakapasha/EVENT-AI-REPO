# ============================================================
# Event-AI — AI Orchestrator Environment Configuration
# ============================================================
# Copy this file to .env and fill in the values.
# Variables marked [REQUIRED] must be set before the service starts.
# Variables marked [OPTIONAL] have safe defaults and can be omitted.
#
# NOTE: The orchestrator also reads from the root .env (../../.env).
#       Variables defined here take precedence over the root file.
# ============================================================

# ── Database ─────────────────────────────────────────────
# [REQUIRED] Pooled connection URL — runtime only.
# Must use pgbouncer=true for Neon pooler (port 6543).
APP_DATABASE_URL=postgresql://USER:PASSWORD@HOST-pooler.neon.tech/neondb?pgbouncer=true&sslmode=require

# ── Gemini / LLM ─────────────────────────────────────────
# [REQUIRED] Google AI API key restricted to Generative Language API.
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# [REQUIRED] Gemini model name — must be prefixed with "gemini/" for LiteLLM routing.
# Default in code: "" (empty — service silently fails if not set).
# Example: gemini/gemini-2.5-flash-lite  |  gemini/gemini-2.5-flash
GEMINI_MODEL=gemini/gemini-2.5-flash

# [OPTIONAL] Gemini OpenAI-compatible base URL. Only change if Google updates the endpoint.
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# ── Backend API ───────────────────────────────────────────
# [OPTIONAL] Base URL for the FastAPI backend (used by agent tools).
BACKEND_API_URL=http://localhost:5000/api/v1

# ── Service-to-Service Auth ───────────────────────────────
# [REQUIRED] Shared HMAC secret for signing requests to the backend.
# Must exactly match AGENT_SERVICE_SECRET in packages/backend/.env.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SERVICE_SECRET=

# [REQUIRED] Bearer token the orchestrator presents to authenticate
# requests from external callers (e.g., user/vendor portals).
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
AI_SERVICE_API_KEY=

# ── CORS ──────────────────────────────────────────────────
# [OPTIONAL] Comma-separated list of allowed origins.
CORS_ORIGINS=http://localhost:3000,http://localhost:3002,http://localhost:3003,http://localhost:3004

# ── Rate Limiting ─────────────────────────────────────────
# [OPTIONAL] Per-user request limit per minute.
RATE_LIMIT_PER_MINUTE=30

# ── Session ───────────────────────────────────────────────
# [OPTIONAL] Mem0 session TTL in days.
SESSION_TTL_DAYS=30

# ── Agent Safety Limits ───────────────────────────────────
# [OPTIONAL] Maximum agent handoff depth — prevents infinite loops.
MAX_HANDOFF_DEPTH=5

# [OPTIONAL] Maximum characters in a single agent response.
MAX_RESPONSE_CHARS=2000

# [OPTIONAL] Maximum characters accepted from user input before firewall truncates.
MAX_INPUT_CHARS=2000

# ── Prompt Injection Firewall ─────────────────────────────
# [OPTIONAL] Path to the injection blocklist YAML (relative to orchestrator root).
INJECTION_BLOCKLIST_PATH=data/injection_blocklist.yaml

# [OPTIONAL] PromptGuard confidence threshold (0.0–1.0).
PROMPTGUARD_THRESHOLD=0.85

# [OPTIONAL] Alignment check threshold (0.0–1.0).
ALIGNMENT_THRESHOLD=0.80

# ── ShieldGemma Safety Classifier ────────────────────────
# [OPTIONAL] Enable LLM-based safety classification.
# Set to "true" in production; keep "false" in development to avoid extra latency.
# NOTE: Read directly via os.getenv() in guardrails.py, not through pydantic-settings.
SHIELDGEMMA_ENABLED=false

# ── Mem0 (Persistent AI Memory) ──────────────────────────
# [OPTIONAL] Provides per-user memory across sessions.
# Get from: https://app.mem0.ai/dashboard/api-keys
MEM0_API_KEY=

# ── TruLens RAG Evaluation ────────────────────────────────
# [OPTIONAL] Enable TruLens evaluation of RAG pipelines.
TRULENS_ENABLED=false

# [OPTIONAL] Minimum groundedness score for RAG answers (0.0–1.0).
TRULENS_GROUNDEDNESS_THRESHOLD=0.70

# ── Model Tuning ──────────────────────────────────────────
# [OPTIONAL] Gemini thinking budget (thinkingConfig.thinkingBudget).
# 0 = disable extended thinking (fastest, lowest token cost).
# 1–24576 = cap thinking tokens at this value.
THINKING_BUDGET=0

# [OPTIONAL] Sampling temperature passed to the model (0.0–2.0).
MODEL_TEMPERATURE=1.0

# [OPTIONAL] Maximum tokens the model may generate per response.
MODEL_MAX_TOKENS=8192
