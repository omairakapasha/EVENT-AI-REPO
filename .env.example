# ============================================================
# Event-AI Platform — Single Root Environment Configuration
# ============================================================
# Copy this file to .env at the project root and fill in values.
# This single file is the source of truth for ALL packages.
# NEVER commit .env to git.
# ============================================================

# ── Node / General ────────────────────────────────────────
NODE_ENV=development
API_VERSION=v1

# ── Ports ─────────────────────────────────────────────────
PORT=5000          # Backend FastAPI
AI_PORT=8000       # AI Orchestrator
USER_PORT=3003     # User portal
FRONTEND_PORT=3002 # Vendor portal
ADMIN_PORT=3004    # Admin portal

# ── Database (Neon PostgreSQL) ────────────────────────────
# Pooled URL — runtime (backend + orchestrator)
DATABASE_URL=postgresql://USER:PASSWORD@HOST-pooler.neon.tech/neondb?sslmode=require
# Direct URL — Alembic migrations ONLY
DIRECT_URL=postgresql://USER:PASSWORD@HOST.neon.tech/neondb?sslmode=require
# Alias used by agentic_event_orchestrator
APP_DATABASE_URL=${DATABASE_URL}

# Individual DB params (fallback)
DB_HOST=
DB_PORT=5432
DB_NAME=neondb
DB_USER=
DB_PASSWORD=

# ── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT ───────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Google OAuth 2.0 ──────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5000/api/v1/auth/google/callback

# ── Gemini / AI ───────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# ── Service-to-Service Auth ───────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
# Must be identical in backend and AI orchestrator
AI_SERVICE_API_KEY=

# ── Internal Service URLs ─────────────────────────────────
BACKEND_API_URL=http://localhost:5000/api/v1
AI_SERVICE_URL=http://localhost:8000
MCP_SERVER_URL=http://localhost:3002

# ── Frontend URLs (public — exposed to browser) ───────────
NEXT_PUBLIC_API_URL=http://localhost:5000/api/v1
FRONTEND_URL=http://localhost:3002

# ── CORS ──────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:3002,http://localhost:3003,http://localhost:3004

# ── Supabase ──────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── CDN / Object Storage (S3-compatible, e.g. Cloudflare R2) ──
CDN_PROVIDER=r2
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=
S3_REGION=auto
S3_USE_SSL=true

# ── Email / SMTP ──────────────────────────────────────────
# Brevo (formerly Sendinblue) — https://app.brevo.com/settings/keys/smtp
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-brevo-login-email@example.com
SMTP_PASSWORD=xsmtpsib-your-brevo-smtp-key-here
EMAIL_FROM=noreply@eventai.pk

# ── Rate Limiting ─────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ── Logging ───────────────────────────────────────────────
LOG_LEVEL=info

# ── Chainlit (AI chat UI) ─────────────────────────────────
CHAINLIT_AUTH_SECRET=

# ── Context7 MCP ──────────────────────────────────────────
# Get from: https://context7.com/dashboard
CONTEXT7_API_KEY=

# ── NextAuth (user + admin portals) ──────────────────────
NEXTAUTH_URL=http://localhost:3003
NEXTAUTH_SECRET=

SMTP_KEY=

# ── Mem0 (persistent AI memory) ──────────────────────────
# Get from: https://app.mem0.ai/dashboard/api-keys
MEM0_API_KEY=